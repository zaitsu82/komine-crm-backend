{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "scripts/**/*.ts",
    "prisma/scripts/**/*.ts",
    "prisma/seed.ts",
    "prisma/seedMasters.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "**/*.test.ts",
    "**/*.spec.ts",
    "scripts/**/*.js"
  ]
}
